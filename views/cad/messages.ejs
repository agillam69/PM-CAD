<%- include('../layout', { body: `

<div class="row mb-4">
  <div class="col-12">
    <div class="d-flex justify-content-between align-items-center">
      <h2>
        <i class="fas fa-envelope text-info"></i>
        Messages
      </h2>
      <a href="/cad" class="btn btn-outline-light">
        <i class="fas fa-arrow-left"></i> Back to Board
      </a>
    </div>
    <p class="text-muted mb-0">Group pages, info messages, and other non-case communications</p>
  </div>
</div>

<div class="row">
  <div class="col-12">
    <div class="table-responsive">
      <table class="table table-dark table-striped table-hover">
        <thead>
          <tr>
            <th style="width: 150px;">Time</th>
            <th style="width: 200px;">Alias</th>
            <th style="width: 120px;">Service</th>
            <th>Message</th>
          </tr>
        </thead>
        <tbody>
          ${messages.length > 0 ? messages.map(m => {
            const serviceConfig = services[m.service] || { name: m.service || 'Unknown', color: '#6c757d' };
            return `
              <tr>
                <td class="text-nowrap">
                  <small>${moment.unix(m.timestamp).format('DD/MM HH:mm:ss')}</small>
                </td>
                <td>
                  <span class="text-info">${m.alias || 'Unknown'}</span>
                </td>
                <td>
                  <span class="badge" style="background-color: ${serviceConfig.color}">
                    ${serviceConfig.name}
                  </span>
                </td>
                <td>
                  <small class="text-light">${m.message.substring(0, 200)}${m.message.length > 200 ? '...' : ''}</small>
                </td>
              </tr>
            `;
          }).join('') : `
            <tr>
              <td colspan="4" class="text-center py-5">
                <i class="fas fa-inbox fa-3x text-muted mb-3"></i>
                <p class="text-muted">No messages yet</p>
              </td>
            </tr>
          `}
        </tbody>
      </table>
    </div>
  </div>
</div>

`, extraScripts: `
<script>
  socket.on('messageUpdate', function(data) {
    location.reload();
  });
</script>
` }) %>
