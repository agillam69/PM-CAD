<%- include('../layout', { body: `

<div class="row mb-3">
  <div class="col-12">
    <div class="d-flex justify-content-between align-items-center">
      <h2><i class="fas fa-exclamation-triangle text-warning"></i> Major & Escalated Incidents</h2>
      <a href="/cad" class="btn btn-outline-light">
        <i class="fas fa-arrow-left"></i> Back to CAD
      </a>
    </div>
  </div>
</div>

<!-- Major Incidents Section -->
<div class="row mb-4">
  <div class="col-12">
    <div class="card border-danger">
      <div class="card-header bg-danger text-white">
        <i class="fas fa-star"></i> Major Incidents (Manual)
        <span class="badge bg-light text-dark ms-2">${majorCases.length}</span>
      </div>
      <div class="card-body">
        ${majorCases.length === 0 ? `
          <p class="text-muted mb-0">No major incidents currently flagged.</p>
        ` : `
          <div class="row">
            ${majorCases.map(c => {
              const svc = services[c.service] || { color: '#6c757d', icon: 'question-circle', name: c.service };
              return `
                <div class="col-lg-4 col-md-6 mb-3">
                  <div class="card case-card border-danger" style="border-width: 3px;">
                    <div class="card-header d-flex justify-content-between align-items-center" style="background-color: ${svc.color};">
                      <span class="case-number text-white">${c.case_number}</span>
                      <div>
                        <span class="badge bg-danger me-1"><i class="fas fa-star"></i> MAJOR</span>
                        ${c.incident_level >= 2 ? '<span class="badge bg-warning text-dark">L' + c.incident_level + '</span>' : ''}
                      </div>
                    </div>
                    <div class="card-body">
                      ${c.incident_description ? '<p class="mb-2 text-warning fw-bold"><i class="fas fa-exclamation-circle"></i> ' + c.incident_description + '</p>' : ''}
                      ${c.address ? '<p class="mb-2 text-white"><i class="fas fa-map-marker-alt text-danger"></i> ' + c.address + '</p>' : ''}
                      <div class="d-flex justify-content-between align-items-center">
                        <span class="text-light"><i class="fas fa-envelope"></i> ${c.message_count || 0} messages</span>
                        <span class="timestamp text-light">${moment.unix(c.last_updated).fromNow()}</span>
                      </div>
                      <div class="mt-2">
                        <a href="/cad/case/${c.case_number}" class="btn btn-sm btn-primary me-1">View</a>
                        <button class="btn btn-sm btn-outline-warning" onclick="toggleMajor('${c.case_number}', false)">
                          <i class="fas fa-star"></i> Unmark Major
                        </button>
                        <button class="btn btn-sm btn-outline-danger" onclick="closeIncident('${c.case_number}')">
                          <i class="fas fa-times"></i> Close
                        </button>
                      </div>
                    </div>
                  </div>
                </div>
              `;
            }).join('')}
          </div>
        `}
      </div>
    </div>
  </div>
</div>

<!-- Level 2+ Escalated Incidents Section -->
<div class="row">
  <div class="col-12">
    <div class="card border-warning">
      <div class="card-header bg-warning text-dark">
        <i class="fas fa-level-up-alt"></i> Level 2+ Incidents (Auto-escalated: 6+ messages)
        <span class="badge bg-dark ms-2">${escalatedCases.filter(c => !c.is_major).length}</span>
      </div>
      <div class="card-body">
        ${escalatedCases.filter(c => !c.is_major).length === 0 ? `
          <p class="text-muted mb-0">No escalated incidents.</p>
        ` : `
          <div class="row">
            ${escalatedCases.filter(c => !c.is_major).map(c => {
              const svc = services[c.service] || { color: '#6c757d', icon: 'question-circle', name: c.service };
              return `
                <div class="col-lg-4 col-md-6 mb-3">
                  <div class="card case-card border-warning" style="border-width: 2px;">
                    <div class="card-header d-flex justify-content-between align-items-center" style="background-color: ${svc.color};">
                      <span class="case-number text-white">${c.case_number}</span>
                      <span class="badge bg-warning text-dark">Level ${c.incident_level}</span>
                    </div>
                    <div class="card-body">
                      ${c.incident_description ? '<p class="mb-2 text-warning fw-bold"><i class="fas fa-exclamation-circle"></i> ' + c.incident_description + '</p>' : ''}
                      ${c.address ? '<p class="mb-2 text-white"><i class="fas fa-map-marker-alt text-danger"></i> ' + c.address + '</p>' : ''}
                      <div class="d-flex justify-content-between align-items-center">
                        <span class="text-light"><i class="fas fa-envelope"></i> ${c.message_count || 0} messages</span>
                        <span class="timestamp text-light">${moment.unix(c.last_updated).fromNow()}</span>
                      </div>
                      <div class="mt-2">
                        <a href="/cad/case/${c.case_number}" class="btn btn-sm btn-primary me-1">View</a>
                        <button class="btn btn-sm btn-outline-danger" onclick="toggleMajor('${c.case_number}', true)">
                          <i class="fas fa-star"></i> Mark Major
                        </button>
                      </div>
                    </div>
                  </div>
                </div>
              `;
            }).join('')}
          </div>
        `}
      </div>
    </div>
  </div>
</div>

`, extraScripts: `
<script>
  function toggleMajor(caseNumber, isMajor) {
    fetch('/cad/api/case/' + caseNumber + '/major', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ major: isMajor })
    })
    .then(response => response.json())
    .then(data => {
      if (data.success) {
        location.reload();
      }
    })
    .catch(err => console.error('Error:', err));
  }
  
  function closeIncident(caseNumber) {
    if (!confirm('Close incident ' + caseNumber + '? This will remove it from the active list.')) {
      return;
    }
    
    fetch('/cad/api/case/' + caseNumber + '/close', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' }
    })
    .then(response => response.json())
    .then(data => {
      if (data.success) {
        location.reload();
      }
    })
    .catch(err => console.error('Error:', err));
  }
</script>
` }) %>
