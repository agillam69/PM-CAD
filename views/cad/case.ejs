<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= locals.case.case_number %> - CAD</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" rel="stylesheet">
  <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
  <style>
    body { background-color: #1a1a2e; color: #fff; }
    .navbar { background-color: #16213e !important; }
    .card { background-color: #16213e; border: 1px solid #0f3460; color: #fff; }
    .card-header { background-color: #0f3460; border-bottom: 1px solid #0f3460; color: #fff; }
    .card-body { color: #fff; }
    .breadcrumb { background: transparent; }
    .breadcrumb-item a { color: #adb5bd; }
    .breadcrumb-item.active { color: #fff; }
    .message-item { padding: 10px; border-bottom: 1px solid #0f3460; }
    .message-item:last-child { border-bottom: none; }
    .service-badge { padding: 4px 8px; border-radius: 4px; font-size: 0.85em; }
    .service-fire { background-color: #dc3545; color: white; }
    .service-ambulance { background-color: #28a745; color: white; }
    .service-ses { background-color: #fd7e14; color: white; }
    .form-control, .form-select { color: #fff !important; }
    .list-group-item { color: #fff; }
    p, span, small, strong, label { color: #fff; }
    .text-muted { color: #adb5bd !important; }
  </style>
</head>
<body>
  <nav class="navbar navbar-expand-lg navbar-dark mb-4">
    <div class="container-fluid">
      <a class="navbar-brand" href="/cad"><i class="fas fa-broadcast-tower"></i> CAD Dispatch</a>
      <div class="navbar-nav ms-auto">
        <a class="nav-link" href="/cad"><i class="fas fa-th-list"></i> Board</a>
        <a class="nav-link" href="/map"><i class="fas fa-map"></i> Map</a>
        <% if (typeof user !== 'undefined' && user) { %>
        <a class="nav-link" href="/auth/logout"><i class="fas fa-sign-out-alt"></i> Logout</a>
        <% } %>
      </div>
    </div>
  </nav>

  <div class="container-fluid">
    <div class="row mb-4">
      <div class="col-12">
        <nav aria-label="breadcrumb">
          <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="/cad">Dispatch Board</a></li>
            <li class="breadcrumb-item active"><%= locals.case.case_number %></li>
          </ol>
        </nav>
      </div>
    </div>

    <div class="row">
      <!-- Case Info -->
      <div class="col-lg-8">
        <div class="card mb-4">
          <div class="card-header d-flex justify-content-between align-items-center">
            <span>
              <i class="fas fa-clipboard-list"></i> Case Details
              <% if (locals.case.is_major) { %>
                <span class="badge bg-danger ms-2"><i class="fas fa-star"></i> MAJOR</span>
              <% } %>
              <% if (locals.case.incident_level >= 2) { %>
                <span class="badge bg-warning text-dark ms-2">Level <%= locals.case.incident_level %></span>
              <% } %>
            </span>
            <div>
              <button class="btn btn-sm <%= locals.case.is_major ? 'btn-warning' : 'btn-outline-danger' %> me-2" onclick="toggleMajor('<%= locals.case.case_number %>', <%= !locals.case.is_major %>)">
                <i class="fas fa-star"></i> <%= locals.case.is_major ? 'Unmark Major' : 'Mark Major' %>
              </button>
              <span class="service-badge service-<%= locals.case.service %>">
                <i class="fas fa-<%= locals.case.serviceConfig.icon || 'question' %>"></i>
                <%= locals.case.serviceConfig.name || locals.case.service %>
              </span>
            </div>
          </div>
          <div class="card-body">
            <div class="row">
              <div class="col-md-6">
                <h3 class="case-number mb-3 text-white"><%= locals.case.case_number %></h3>
                
                <% if (locals.case.address) { %>
                  <p class="mb-2 text-light">
                    <strong class="text-white"><i class="fas fa-map-marker-alt text-danger"></i> Address:</strong><br>
                    <%= locals.case.address %>
                  </p>
                <% } %>
                
                <% if (locals.case.map_ref) { %>
                  <p class="mb-2 text-light">
                    <strong class="text-white"><i class="fas fa-map"></i> Map Reference:</strong><br>
                    <%= locals.case.map_ref %>
                  </p>
                <% } %>
                
                <% if (locals.case.radio_channel) { %>
                  <p class="mb-2 text-light">
                    <strong class="text-white"><i class="fas fa-broadcast-tower text-warning"></i> Radio Channel:</strong><br>
                    <span class="badge bg-warning text-dark"><%= locals.case.radio_channel %></span>
                  </p>
                <% } %>
                
                <p class="mb-2 text-light">
                  <strong class="text-white"><i class="fas fa-clock"></i> First Seen:</strong><br>
                  <span class="timestamp text-light"><%= moment.unix(locals.case.first_seen).format('DD/MM/YYYY HH:mm:ss') %></span>
                </p>
                
                <p class="mb-2 text-light">
                  <strong class="text-white"><i class="fas fa-sync"></i> Last Updated:</strong><br>
                  <span class="timestamp text-light"><%= moment.unix(locals.case.last_updated).format('DD/MM/YYYY HH:mm:ss') %></span>
                  <small class="text-light">(<%= moment.unix(locals.case.last_updated).fromNow() %>)</small>
                </p>
              </div>
              
              <div class="col-md-6">
                <!-- Mini Map -->
                <% if (locals.case.latitude && locals.case.longitude) { %>
                  <div id="case-map" style="height: 250px; border-radius: 8px;"></div>
                <% } else { %>
                  <div class="text-center py-5 bg-dark rounded">
                    <i class="fas fa-map-marked-alt fa-3x text-muted mb-2"></i>
                    <p class="text-muted">Location not available</p>
                  </div>
                <% } %>
              </div>
            </div>
          </div>
        </div>
        
        <!-- Add Note Form -->
        <div class="card mb-4">
          <div class="card-header">
            <i class="fas fa-sticky-note"></i> Add Note
          </div>
          <div class="card-body">
            <form id="add-note-form" onsubmit="addNote(event)">
              <div class="mb-3">
                <textarea class="form-control bg-dark text-white" id="note-text" rows="2" placeholder="Enter note..." required></textarea>
              </div>
              <div class="row">
                <div class="col-md-6 mb-2">
                  <input type="text" class="form-control bg-dark text-white" id="note-author" placeholder="Author" value="<%= typeof user !== 'undefined' && user ? (user.display_name || user.username) : '' %>" readonly>
                </div>
                <div class="col-md-6 mb-2">
                  <button type="submit" class="btn btn-primary w-100"><i class="fas fa-plus"></i> Add Note</button>
                </div>
              </div>
            </form>
          </div>
        </div>
        
        <!-- Message Timeline -->
        <div class="card mb-4">
          <div class="card-header">
            <i class="fas fa-history"></i> Message Timeline
            <span class="badge bg-secondary" id="timeline-count"><%= (locals.case.messages || []).length + (locals.case.notes || []).length %></span>
          </div>
          <div class="card-body">
            <div class="message-timeline" id="message-timeline">
              <%
                var messages = (locals.case.messages || []).map(function(m) { return { timestamp: m.timestamp, type: 'message', message: m.message, source: m.source }; });
                var notes = (locals.case.notes || []).map(function(n) { return { timestamp: n.timestamp, type: 'note', note: n.note, author: n.author }; });
                var combined = messages.concat(notes).sort(function(a, b) { return a.timestamp - b.timestamp; });
              %>
              <% if (combined.length === 0) { %>
                <p class="text-muted">No messages recorded</p>
              <% } else { %>
                <% combined.forEach(function(item) { %>
                  <% if (item.type === 'note') { %>
                    <div class="message-item" style="border-left: 3px solid #ffc107;">
                      <div class="d-flex justify-content-between">
                        <span class="timestamp text-light"><%= moment.unix(item.timestamp).format('HH:mm:ss') %></span>
                        <span class="badge bg-warning text-dark"><i class="fas fa-sticky-note"></i> NOTE</span>
                      </div>
                      <p class="mb-0 mt-1 text-warning" style="word-break: break-word;"><%= item.note %></p>
                      <% if (item.author) { %>
                        <small class="text-muted">- <%= item.author %></small>
                      <% } %>
                    </div>
                  <% } else { %>
                    <div class="message-item">
                      <div class="d-flex justify-content-between">
                        <span class="timestamp text-light"><%= moment.unix(item.timestamp).format('HH:mm:ss') %></span>
                        <% if (item.source) { %>
                          <span class="badge bg-secondary"><%= item.source %></span>
                        <% } %>
                      </div>
                      <p class="mb-0 mt-1 text-white" style="font-family: monospace; word-break: break-word;"><%= item.message %></p>
                    </div>
                  <% } %>
                <% }); %>
              <% } %>
            </div>
          </div>
        </div>
      </div>
      
      <!-- Resources Sidebar -->
      <div class="col-lg-4">
        <div class="card mb-4">
          <div class="card-header">
            <i class="fas fa-truck"></i> Assigned Resources
            <span class="badge bg-secondary"><%= locals.case.resources.length %></span>
          </div>
          <div class="card-body">
            <% if (locals.case.resources.length > 0) { %>
              <div class="list-group list-group-flush">
                <% locals.case.resources.forEach(function(r) { %>
                  <div class="list-group-item bg-transparent border-secondary d-flex justify-content-between align-items-center">
                    <span class="resource-badge text-white"><%= r.resource_code %></span>
                    <small class="text-light"><%= moment.unix(r.first_seen).format('HH:mm') %></small>
                  </div>
                <% }); %>
              </div>
            <% } else { %>
              <p class="text-muted text-center py-3">No resources assigned</p>
            <% } %>
          </div>
        </div>
        
        <!-- Quick Actions -->
        <div class="card mb-4">
          <div class="card-header">
            <i class="fas fa-bolt"></i> Actions
          </div>
          <div class="card-body">
            <a href="/map?case=<%= locals.case.case_number %>" class="btn btn-outline-primary w-100 mb-2">
              <i class="fas fa-map-marked-alt"></i> View on Map
            </a>
            <a href="/cad" class="btn btn-outline-secondary w-100">
              <i class="fas fa-arrow-left"></i> Back to Board
            </a>
          </div>
        </div>
        
        <!-- Print Options -->
        <div class="card">
          <div class="card-header">
            <i class="fas fa-print"></i> Print
          </div>
          <div class="card-body">
            <a href="/cad/case/<%= locals.case.case_number %>/print/dispatch" target="_blank" class="btn btn-warning w-100 mb-2">
              <i class="fas fa-file-alt"></i> Print Dispatch Slip
            </a>
            <a href="/cad/case/<%= locals.case.case_number %>/print/log" target="_blank" class="btn btn-outline-info w-100">
              <i class="fas fa-file-pdf"></i> Print Case Log
            </a>
          </div>
        </div>
      </div>
    </div>
  </div>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
  <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
  <script src="/socket.io/socket.io.js"></script>
  <script>
    var socket = io();
    
    <% if (locals.case.latitude && locals.case.longitude) { %>
    // Initialize mini map
    var map = L.map('case-map').setView([<%= locals.case.latitude %>, <%= locals.case.longitude %>], 15);
    
    L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
      attribution: '© OpenStreetMap contributors'
    }).addTo(map);
    
    // Add marker
    var marker = L.marker([<%= locals.case.latitude %>, <%= locals.case.longitude %>]).addTo(map);
    marker.bindPopup('<strong><%= locals.case.case_number %></strong><br><%= locals.case.address || "" %>').openPopup();
    <% } %>
    
    // Listen for updates to this case
    socket.on('caseUpdate', function(data) {
      if (data.case && data.case.case_number === '<%= locals.case.case_number %>') {
        location.reload();
      }
    });
    
    // Toggle major incident status
    function toggleMajor(caseNumber, isMajor) {
      fetch('/cad/api/case/' + caseNumber + '/major', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ major: isMajor })
      })
      .then(function(response) { return response.json(); })
      .then(function(data) {
        if (data.success) {
          location.reload();
        }
      })
      .catch(function(err) { console.error('Error:', err); });
    }
    
    // Add note to case
    function addNote(event) {
      event.preventDefault();
      var note = document.getElementById('note-text').value.trim();
      var author = document.getElementById('note-author').value.trim();
      
      if (!note) {
        alert('Please enter a note');
        return;
      }
      
      fetch('/cad/api/case/<%= locals.case.case_number %>/note', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ note: note, author: author || null })
      })
      .then(function(response) {
        if (!response.ok) {
          return response.json().then(function(data) {
            throw new Error(data.error || 'Server error: ' + response.status);
          });
        }
        return response.json();
      })
      .then(function(data) {
        if (data.success) {
          location.reload();
        } else {
          alert('Error adding note: ' + (data.error || 'Unknown error'));
        }
      })
      .catch(function(err) {
        console.error('Error adding note:', err);
        alert('Error adding note: ' + err.message);
      });
    }
  </script>
</body>
</html>
