<%- include('../layout', { body: `

<div class="row mb-4">
  <div class="col-12">
    <div class="d-flex justify-content-between align-items-center">
      <h2>
        <i class="fas fa-${serviceConfig.icon}" style="color: ${serviceConfig.color}"></i>
        ${serviceConfig.name}
      </h2>
      <a href="/cad" class="btn btn-outline-light">
        <i class="fas fa-arrow-left"></i> All Services
      </a>
    </div>
  </div>
</div>

<div class="row" id="cases-container">
  ${cases.length > 0 ? cases.map(c => `
    <div class="col-lg-4 col-md-6 mb-3">
      <div class="card case-card" onclick="window.location='/cad/case/${c.case_number}'" 
           style="border-left: 4px solid ${serviceConfig.color}">
        <div class="card-header d-flex justify-content-between align-items-center">
          <span class="case-number text-white">${c.case_number}</span>
          <span class="badge" style="background-color: ${serviceConfig.color}">
            ${c.resourceCount} units
          </span>
        </div>
        <div class="card-body">
          ${c.address ? `
            <p class="mb-2 text-white">
              <i class="fas fa-map-marker-alt text-danger"></i> ${c.address}
            </p>
          ` : ''}
          ${c.map_ref ? `
            <p class="mb-2 text-light">
              <i class="fas fa-map"></i> Map: ${c.map_ref}
            </p>
          ` : ''}
          <div class="text-end">
            <span class="timestamp text-light">${moment.unix(c.last_updated).fromNow()}</span>
          </div>
        </div>
      </div>
    </div>
  `).join('') : `
    <div class="col-12 text-center py-5">
      <i class="fas fa-inbox fa-4x text-muted mb-3"></i>
      <h4 class="text-muted">No active ${serviceConfig.name} cases</h4>
    </div>
  `}
</div>

`, extraScripts: `
<script>
  socket.emit('join', '${service}');
  
  socket.on('caseUpdate', function(data) {
    if (data.case && data.case.service === '${service}') {
      location.reload();
    }
  });
</script>
` }) %>
