<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %> - PagerMon CAD</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
  <style>
    body {
      background-color: #121212;
      color: #ffffff;
    }
    .card {
      background-color: #1e1e1e;
      border: 1px solid #333;
    }
    .card-header {
      background-color: #2d2d2d;
      border-bottom: 1px solid #333;
    }
    .table-dark {
      background-color: #1e1e1e;
    }
    .badge {
      font-size: 0.8em;
    }
    .pagination .page-link {
      background-color: #2d2d2d;
      border-color: #444;
      color: #fff;
    }
    .pagination .page-link:hover {
      background-color: #444;
      color: #fff;
    }
    .pagination .page-item.active .page-link {
      background-color: #0d6efd;
      border-color: #0d6efd;
    }
  </style>
</head>
<body>
  <nav class="navbar navbar-expand-lg navbar-dark bg-dark">
    <div class="container-fluid">
      <a class="navbar-brand" href="/cad">
        <i class="fas fa-fire-extinguisher"></i> PagerMon CAD
      </a>
      <div class="navbar-nav ms-auto">
        <a class="nav-link" href="/cad">
          <i class="fas fa-tachometer-alt"></i> Active Cases
        </a>
        <a class="nav-link active" href="/cad/archive">
          <i class="fas fa-archive"></i> Archive
        </a>
        <a class="nav-link" href="/settings">
          <i class="fas fa-cog"></i> Settings
        </a>
      </div>
    </div>
  </nav>

  <div class="container-fluid mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
      <h1><i class="fas fa-archive"></i> Case Archive</h1>
      <div>
        <span class="badge bg-secondary"><%= totalCases %> Total Cases</span>
      </div>
    </div>

    <% if (messages && messages.success) { %>
      <div class="alert alert-success alert-dismissible fade show" role="alert">
        <%= messages.success %>
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
      </div>
    <% } %>

    <% if (messages && messages.error) { %>
      <div class="alert alert-danger alert-dismissible fade show" role="alert">
        <%= messages.error %>
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
      </div>
    <% } %>

    <!-- Service Filter -->
    <div class="row mb-3">
      <div class="col">
        <div class="btn-group" role="group">
          <a href="/cad/archive" class="btn <%= !currentService ? 'btn-primary' : 'btn-secondary' %>">
            All Services (<%= cases.all.length %>)
          </a>
          <% Object.keys(services).forEach(function(service) { %>
            <% if (cases[service] && cases[service].length > 0) { %>
              <a href="/cad/archive?service=<%= service %>" class="btn <%= currentService === service ? 'btn-primary' : 'btn-secondary' %>">
                <i class="fas <%= services[service].icon %>"></i> <%= services[service].name %> (<%= cases[service].length %>)
              </a>
            <% } %>
          <% }); %>
        </div>
      </div>
    </div>

    <!-- Cases Table -->
    <div class="card">
      <div class="card-header">
        <h5 class="mb-0">
          <i class="fas fa-archive"></i> Archived Cases
          <% if (currentService && services[currentService]) { %>
            - <%= services[currentService].name %>
          <% } %>
        </h5>
      </div>
      <div class="card-body p-0">
        <div class="table-responsive">
          <table class="table table-dark table-hover mb-0">
            <thead>
              <tr>
                <th>Case #</th>
                <th>Service</th>
                <th>Address</th>
                <th>Priority</th>
                <th>Resources</th>
                <th>Last Updated</th>
                <th>Actions</th>
              </tr>
            </thead>
            <tbody>
              <% const displayCases = currentService ? (cases[currentService] || []) : cases.all; %>
              <% if (displayCases.length === 0) { %>
                <tr>
                  <td colspan="7" class="text-center text-muted py-4">
                    No archived cases found
                  </td>
                </tr>
              <% } else { %>
                <% displayCases.forEach(function(caseItem) { %>
                  <tr>
                    <td>
                      <a href="/cad/case/<%= caseItem.case_number %>" class="text-decoration-none">
                        <%= caseItem.case_number %>
                      </a>
                    </td>
                    <td>
                      <% if (caseItem.serviceConfig) { %>
                        <span class="badge" style="background-color: <%= caseItem.serviceConfig.color %>">
                          <i class="fas <%= caseItem.serviceConfig.icon %>"></i> 
                          <%= caseItem.serviceConfig.name %>
                        </span>
                      <% } else { %>
                        <span class="badge bg-secondary"><%= caseItem.service %></span>
                      <% } %>
                    </td>
                    <td>
                      <% if (caseItem.address) { %>
                        <%= caseItem.address %>
                      <% } else { %>
                        <span class="text-muted">No address</span>
                      <% } %>
                    </td>
                    <td>
                      <% if (caseItem.is_priority) { %>
                        <span class="badge bg-danger">
                          <i class="fas fa-exclamation-triangle"></i> Priority
                        </span>
                      <% } else { %>
                        <span class="badge bg-secondary">Normal</span>
                      <% } %>
                    </td>
                    <td>
                      <span class="badge bg-info">
                        <i class="fas fa-users"></i> <%= caseItem.resourceCount %>
                      </span>
                    </td>
                    <td>
                      <small class="text-muted">
                        <%= moment(caseItem.last_updated * 1000).fromNow() %>
                      </small>
                    </td>
                    <td>
                      <div class="btn-group btn-group-sm" role="group">
                        <a href="/cad/case/<%= caseItem.case_number %>" class="btn btn-outline-info btn-sm">
                          <i class="fas fa-eye"></i>
                        </a>
                        <form method="POST" action="/cad/archive/restore/<%= caseItem.case_number %>" style="display: inline;">
                          <button type="submit" class="btn btn-outline-warning btn-sm" 
                                  onclick="return confirm('Restore case <%= caseItem.case_number %> to active?')">
                            <i class="fas fa-undo"></i>
                          </button>
                        </form>
                        <form method="POST" action="/cad/archive/delete/<%= caseItem.case_number %>" style="display: inline;">
                          <button type="submit" class="btn btn-outline-danger btn-sm" 
                                  onclick="return confirm('Permanently delete case <%= caseItem.case_number %>? This cannot be undone.')">
                            <i class="fas fa-trash"></i>
                          </button>
                        </form>
                      </div>
                    </td>
                  </tr>
                <% }); %>
              <% } %>
            </tbody>
          </table>
        </div>
      </div>
    </div>

    <!-- Pagination -->
    <% if (totalPages > 1) { %>
      <nav aria-label="Archive pagination" class="mt-4">
        <ul class="pagination justify-content-center">
          <% if (currentPage > 1) { %>
            <li class="page-item">
              <a class="page-link" href="/cad/archive?page=<%= currentPage - 1 %><%= currentService ? '&service=' + currentService : '' %>">
                <i class="fas fa-chevron-left"></i> Previous
              </a>
            </li>
          <% } %>
          
          <% for (let i = 1; i <= totalPages; i++) { %>
            <% if (i === currentPage || i === 1 || i === totalPages || (i >= currentPage - 1 && i <= currentPage + 1)) { %>
              <li class="page-item <%= i === currentPage ? 'active' : '' %>">
                <a class="page-link" href="/cad/archive?page=<%= i %><%= currentService ? '&service=' + currentService : '' %>">
                  <%= i %>
                </a>
              </li>
            <% } else if (i === currentPage - 2 || i === currentPage + 2) { %>
              <li class="page-item disabled">
                <span class="page-link">...</span>
              </li>
            <% } %>
          <% } %>
          
          <% if (currentPage < totalPages) { %>
            <li class="page-item">
              <a class="page-link" href="/cad/archive?page=<%= currentPage + 1 %><%= currentService ? '&service=' + currentService : '' %>">
                Next <i class="fas fa-chevron-right"></i>
              </a>
            </li>
          <% } %>
        </ul>
      </nav>
    <% } %>
  </div>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
