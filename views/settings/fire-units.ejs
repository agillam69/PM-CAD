<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Fire Unit Codes - CAD</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" rel="stylesheet">
  <style>
    body { background-color: #1a1a2e; color: #fff; }
    .navbar { background-color: #16213e !important; }
    .card { background-color: #16213e; border: 1px solid #0f3460; }
    .card-header { background-color: #0f3460; border-bottom: 1px solid #0f3460; }
    .table { color: #fff; }
    .btn-close-white { filter: invert(1); }
    .type-appliance { color: #dc3545; }
    .type-commander { color: #ffc107; }
    .type-radio { color: #6c757d; }
    .type-unit { color: #17a2b8; }
  </style>
</head>
<body>
  <nav class="navbar navbar-expand-lg navbar-dark mb-4">
    <div class="container-fluid">
      <a class="navbar-brand" href="/cad"><i class="fas fa-broadcast-tower"></i> CAD Dispatch</a>
      <div class="navbar-nav ms-auto">
        <a class="nav-link" href="/settings"><i class="fas fa-arrow-left"></i> Back to Settings</a>
        <a class="nav-link" href="/cad"><i class="fas fa-th-list"></i> Board</a>
      </div>
    </div>
  </nav>

  <div class="container-fluid">
    <div class="row mb-4">
      <div class="col-12">
        <div class="d-flex justify-content-between align-items-center">
          <h2><i class="fas fa-fire-extinguisher"></i> Fire Unit Codes</h2>
          <button class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#addUnitModal">
            <i class="fas fa-plus"></i> Add Unit Code
          </button>
        </div>
        <p class="text-muted mt-2">
          Manage fire unit codes to display friendly names for appliances, commanders, and radio channels.
          Codes extracted from fire messages will be cross-referenced against this list.
        </p>
      </div>
    </div>

    <div class="row">
      <div class="col-lg-8">
        <div class="card">
          <div class="card-header">
            <i class="fas fa-list"></i> Unit Codes
            <span class="badge bg-secondary"><%= unitCodes.length %></span>
          </div>
          <div class="card-body">
            <table class="table table-dark table-hover">
              <thead>
                <tr>
                  <th>Code</th>
                  <th>Name</th>
                  <th>Type</th>
                  <th>Actions</th>
                </tr>
              </thead>
              <tbody>
                <% unitCodes.forEach(function(unit) { %>
                <tr>
                  <td><code><%= unit.code %></code></td>
                  <td><%= unit.name %></td>
                  <td>
                    <span class="type-<%= unit.type %>">
                      <% if (unit.type === 'appliance') { %>
                        <i class="fas fa-fire-extinguisher"></i> Appliance
                      <% } else if (unit.type === 'commander') { %>
                        <i class="fas fa-user-tie"></i> Commander
                      <% } else if (unit.type === 'radio') { %>
                        <i class="fas fa-broadcast-tower"></i> Radio
                      <% } else { %>
                        <i class="fas fa-truck"></i> Unit
                      <% } %>
                    </span>
                  </td>
                  <td>
                    <button class="btn btn-sm btn-outline-primary" onclick="editUnit(<%= unit.id %>, '<%= unit.code %>', '<%= unit.name %>', '<%= unit.type %>')">
                      <i class="fas fa-edit"></i>
                    </button>
                    <button class="btn btn-sm btn-outline-danger" onclick="deleteUnit(<%= unit.id %>, '<%= unit.code %>')">
                      <i class="fas fa-trash"></i>
                    </button>
                  </td>
                </tr>
                <% }); %>
                <% if (unitCodes.length === 0) { %>
                <tr>
                  <td colspan="4" class="text-center text-muted">No unit codes defined</td>
                </tr>
                <% } %>
              </tbody>
            </table>
          </div>
        </div>
      </div>
      
      <div class="col-lg-4">
        <div class="card mb-4">
          <div class="card-header">
            <i class="fas fa-info-circle"></i> Unit Types
          </div>
          <div class="card-body">
            <p class="mb-2"><span class="type-appliance"><i class="fas fa-fire-extinguisher"></i> Appliance</span> - Fire trucks, tankers, pumpers (PT5, R44)</p>
            <p class="mb-2"><span class="type-commander"><i class="fas fa-user-tie"></i> Commander</span> - Officers/commanders (DWOO, SAHA)</p>
            <p class="mb-2"><span class="type-radio"><i class="fas fa-broadcast-tower"></i> Radio</span> - Radio channels (FGD15, FGD551)</p>
            <p class="mb-0"><span class="type-unit"><i class="fas fa-truck"></i> Unit</span> - Other units</p>
          </div>
        </div>
        
        <div class="card">
          <div class="card-header">
            <i class="fas fa-lightbulb"></i> Common Codes
          </div>
          <div class="card-body">
            <p class="small mb-2"><strong>Pumper Tankers:</strong> PT1-PT99</p>
            <p class="small mb-2"><strong>Pumpers:</strong> P1-P99</p>
            <p class="small mb-2"><strong>Tankers:</strong> T1-T99</p>
            <p class="small mb-2"><strong>Rescue:</strong> R1-R99</p>
            <p class="small mb-2"><strong>Ladder Platform:</strong> LP1-LP9</p>
            <p class="small mb-0"><strong>Radio Channels:</strong> FGD1-FGD999</p>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Add Unit Modal -->
  <div class="modal fade" id="addUnitModal" tabindex="-1">
    <div class="modal-dialog">
      <div class="modal-content bg-dark">
        <div class="modal-header">
          <h5 class="modal-title"><i class="fas fa-plus"></i> Add Unit Code</h5>
          <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
        </div>
        <form id="addUnitForm" onsubmit="addUnit(event)">
          <div class="modal-body">
            <div class="mb-3">
              <label class="form-label">Code</label>
              <input type="text" class="form-control bg-dark text-white" name="code" placeholder="e.g., PT5, DWOO" required>
              <small class="text-muted">The code as it appears in pager messages</small>
            </div>
            <div class="mb-3">
              <label class="form-label">Name</label>
              <input type="text" class="form-control bg-dark text-white" name="name" placeholder="e.g., Pumper Tanker 5, Damien Wood" required>
              <small class="text-muted">Friendly display name</small>
            </div>
            <div class="mb-3">
              <label class="form-label">Type</label>
              <select class="form-select bg-dark text-white" name="type">
                <option value="appliance">Appliance (fire truck, tanker)</option>
                <option value="commander">Commander (officer)</option>
                <option value="radio">Radio Channel</option>
                <option value="unit">Other Unit</option>
              </select>
            </div>
          </div>
          <div class="modal-footer">
            <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
            <button type="submit" class="btn btn-primary">Add Code</button>
          </div>
        </form>
      </div>
    </div>
  </div>

  <!-- Edit Unit Modal -->
  <div class="modal fade" id="editUnitModal" tabindex="-1">
    <div class="modal-dialog">
      <div class="modal-content bg-dark">
        <div class="modal-header">
          <h5 class="modal-title"><i class="fas fa-edit"></i> Edit Unit Code</h5>
          <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
        </div>
        <form id="editUnitForm" onsubmit="saveUnit(event)">
          <input type="hidden" name="unitId" id="editUnitId">
          <div class="modal-body">
            <div class="mb-3">
              <label class="form-label">Code</label>
              <input type="text" class="form-control bg-dark text-white" name="code" id="editCode" required>
            </div>
            <div class="mb-3">
              <label class="form-label">Name</label>
              <input type="text" class="form-control bg-dark text-white" name="name" id="editName" required>
            </div>
            <div class="mb-3">
              <label class="form-label">Type</label>
              <select class="form-select bg-dark text-white" name="type" id="editType">
                <option value="appliance">Appliance (fire truck, tanker)</option>
                <option value="commander">Commander (officer)</option>
                <option value="radio">Radio Channel</option>
                <option value="unit">Other Unit</option>
              </select>
            </div>
          </div>
          <div class="modal-footer">
            <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
            <button type="submit" class="btn btn-primary">Save Changes</button>
          </div>
        </form>
      </div>
    </div>
  </div>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
  <script>
    function addUnit(event) {
      event.preventDefault();
      var form = event.target;
      var data = {
        code: form.code.value,
        name: form.name.value,
        type: form.type.value
      };
      
      fetch('/settings/api/fire-units', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(data)
      })
      .then(function(res) { return res.json(); })
      .then(function(result) {
        if (result.success) {
          location.reload();
        } else {
          alert('Error: ' + result.error);
        }
      })
      .catch(function(err) { alert('Error adding unit code'); });
    }
    
    function editUnit(id, code, name, type) {
      document.getElementById('editUnitId').value = id;
      document.getElementById('editCode').value = code;
      document.getElementById('editName').value = name;
      document.getElementById('editType').value = type;
      
      new bootstrap.Modal(document.getElementById('editUnitModal')).show();
    }
    
    function saveUnit(event) {
      event.preventDefault();
      var form = event.target;
      var id = document.getElementById('editUnitId').value;
      var data = {
        code: form.code.value,
        name: form.name.value,
        type: form.type.value
      };
      
      fetch('/settings/api/fire-units/' + id, {
        method: 'PUT',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(data)
      })
      .then(function(res) { return res.json(); })
      .then(function(result) {
        if (result.success) {
          location.reload();
        } else {
          alert('Error: ' + result.error);
        }
      })
      .catch(function(err) { alert('Error updating unit code'); });
    }
    
    function deleteUnit(id, code) {
      if (!confirm('Delete unit code "' + code + '"?')) {
        return;
      }
      
      fetch('/settings/api/fire-units/' + id, {
        method: 'DELETE'
      })
      .then(function(res) { return res.json(); })
      .then(function(result) {
        if (result.success) {
          location.reload();
        } else {
          alert('Error: ' + result.error);
        }
      })
      .catch(function(err) { alert('Error deleting unit code'); });
    }
  </script>
</body>
</html>
