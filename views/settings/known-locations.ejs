<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= pageTitle %> - CAD Settings</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" rel="stylesheet">
  <style>
    body { background-color: #1a1a2e; color: #fff; }
    .navbar { background-color: #16213e !important; }
    .card { background-color: #16213e; border: 1px solid #0f3460; }
    .card-header { background-color: #0f3460; border-bottom: 1px solid #0f3460; }
    .table { color: #fff; }
    .table-dark { background-color: #16213e; }
    .form-control, .form-select { 
      background-color: #0f3460; 
      border-color: #0f3460; 
      color: #fff; 
    }
    .form-control:focus, .form-select:focus { 
      background-color: #16213e; 
      border-color: #4a90d9; 
      color: #fff; 
    }
    .btn-outline-light:hover { background-color: rgba(255,255,255,0.1); }
  </style>
</head>
<body>
  <nav class="navbar navbar-expand-lg navbar-dark mb-4">
    <div class="container-fluid">
      <a class="navbar-brand" href="/cad"><i class="fas fa-broadcast-tower"></i> CAD Dispatch</a>
      <div class="navbar-nav ms-auto">
        <a class="nav-link" href="/cad"><i class="fas fa-th-list"></i> Board</a>
        <a class="nav-link" href="/map"><i class="fas fa-map"></i> Map</a>
        <a class="nav-link active" href="/settings"><i class="fas fa-cog"></i> Settings</a>
      </div>
    </div>
  </nav>

  <div class="container-fluid">
    <div class="row mb-4">
      <div class="col-12">
        <nav aria-label="breadcrumb">
          <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="/settings" class="text-light">Settings</a></li>
            <li class="breadcrumb-item active text-white">Known Locations</li>
          </ol>
        </nav>
      </div>
    </div>

    <div class="row">
      <div class="col-lg-8">
        <div class="card mb-4">
          <div class="card-header d-flex justify-content-between align-items-center">
            <span><i class="fas fa-map-marker-alt"></i> Known Locations</span>
            <button class="btn btn-sm btn-success" data-bs-toggle="modal" data-bs-target="#addLocationModal">
              <i class="fas fa-plus"></i> Add Location
            </button>
          </div>
          <div class="card-body p-0">
            <div class="table-responsive">
              <table class="table table-dark table-hover mb-0">
                <thead>
                  <tr>
                    <th>Code</th>
                    <th>Name</th>
                    <th>Address</th>
                    <th>Coordinates</th>
                    <th>Status</th>
                    <th>Actions</th>
                  </tr>
                </thead>
                <tbody id="locationsTable">
                  <% if (locations.length === 0) { %>
                    <tr>
                      <td colspan="6" class="text-center text-muted py-4">
                        No known locations configured. Add one to get started.
                      </td>
                    </tr>
                  <% } else { %>
                    <% locations.forEach(function(loc) { %>
                      <tr data-id="<%= loc.id %>">
                        <td><code><%= loc.code %></code></td>
                        <td><%= loc.name %></td>
                        <td><small><%= loc.address %></small></td>
                        <td>
                          <% if (loc.latitude && loc.longitude) { %>
                            <small class="text-info"><%= loc.latitude.toFixed(4) %>, <%= loc.longitude.toFixed(4) %></small>
                          <% } else { %>
                            <span class="text-warning"><i class="fas fa-exclamation-triangle"></i> Not set</span>
                          <% } %>
                        </td>
                        <td>
                          <% if (loc.enabled) { %>
                            <span class="badge bg-success">Enabled</span>
                          <% } else { %>
                            <span class="badge bg-secondary">Disabled</span>
                          <% } %>
                        </td>
                        <td>
                          <button class="btn btn-sm btn-outline-primary" onclick="editLocation(<%= loc.id %>)">
                            <i class="fas fa-edit"></i>
                          </button>
                          <button class="btn btn-sm btn-outline-danger" onclick="deleteLocation(<%= loc.id %>, '<%= loc.code %>')">
                            <i class="fas fa-trash"></i>
                          </button>
                        </td>
                      </tr>
                    <% }); %>
                  <% } %>
                </tbody>
              </table>
            </div>
          </div>
        </div>
      </div>

      <div class="col-lg-4">
        <div class="card">
          <div class="card-header">
            <i class="fas fa-info-circle"></i> About Known Locations
          </div>
          <div class="card-body">
            <p>Known locations allow you to map location codes (like "AAMB - Essendon") to actual addresses with coordinates.</p>
            <p>When a case address matches a known location code, the system will:</p>
            <ul>
              <li>Use the stored coordinates for mapping</li>
              <li>Display the full address as subtext</li>
              <li>Skip geocoding lookup (faster)</li>
            </ul>
            <p class="mb-0"><strong>Tip:</strong> Use the "Geocode" button when adding a location to automatically get coordinates from the address.</p>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Add Location Modal -->
  <div class="modal fade" id="addLocationModal" tabindex="-1">
    <div class="modal-dialog">
      <div class="modal-content bg-dark text-white">
        <div class="modal-header border-secondary">
          <h5 class="modal-title"><i class="fas fa-plus"></i> Add Known Location</h5>
          <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
        </div>
        <div class="modal-body">
          <form id="addLocationForm">
            <div class="mb-3">
              <label class="form-label">Location Code *</label>
              <input type="text" class="form-control" id="addCode" required placeholder="e.g., AAMB - Essendon">
              <small class="text-muted">The code that appears in messages</small>
            </div>
            <div class="mb-3">
              <label class="form-label">Display Name *</label>
              <input type="text" class="form-control" id="addName" required placeholder="e.g., Air Ambulance Essendon">
            </div>
            <div class="mb-3">
              <label class="form-label">Full Address *</label>
              <div class="input-group">
                <input type="text" class="form-control" id="addAddress" required placeholder="e.g., Unit 3/12 Global Ave, Essendon Fields VIC 3041">
                <button type="button" class="btn btn-outline-info" onclick="geocodeAddress('add')">
                  <i class="fas fa-search-location"></i> Geocode
                </button>
              </div>
            </div>
            <div class="row">
              <div class="col-6">
                <div class="mb-3">
                  <label class="form-label">Latitude</label>
                  <input type="number" step="any" class="form-control" id="addLatitude" placeholder="-37.7234">
                </div>
              </div>
              <div class="col-6">
                <div class="mb-3">
                  <label class="form-label">Longitude</label>
                  <input type="number" step="any" class="form-control" id="addLongitude" placeholder="144.9012">
                </div>
              </div>
            </div>
            <div class="mb-3">
              <label class="form-label">Notes</label>
              <textarea class="form-control" id="addNotes" rows="2" placeholder="Optional notes"></textarea>
            </div>
          </form>
        </div>
        <div class="modal-footer border-secondary">
          <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
          <button type="button" class="btn btn-success" onclick="saveLocation()">
            <i class="fas fa-save"></i> Save Location
          </button>
        </div>
      </div>
    </div>
  </div>

  <!-- Edit Location Modal -->
  <div class="modal fade" id="editLocationModal" tabindex="-1">
    <div class="modal-dialog">
      <div class="modal-content bg-dark text-white">
        <div class="modal-header border-secondary">
          <h5 class="modal-title"><i class="fas fa-edit"></i> Edit Known Location</h5>
          <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
        </div>
        <div class="modal-body">
          <form id="editLocationForm">
            <input type="hidden" id="editId">
            <div class="mb-3">
              <label class="form-label">Location Code *</label>
              <input type="text" class="form-control" id="editCode" required>
            </div>
            <div class="mb-3">
              <label class="form-label">Display Name *</label>
              <input type="text" class="form-control" id="editName" required>
            </div>
            <div class="mb-3">
              <label class="form-label">Full Address *</label>
              <div class="input-group">
                <input type="text" class="form-control" id="editAddress" required>
                <button type="button" class="btn btn-outline-info" onclick="geocodeAddress('edit')">
                  <i class="fas fa-search-location"></i> Geocode
                </button>
              </div>
            </div>
            <div class="row">
              <div class="col-6">
                <div class="mb-3">
                  <label class="form-label">Latitude</label>
                  <input type="number" step="any" class="form-control" id="editLatitude">
                </div>
              </div>
              <div class="col-6">
                <div class="mb-3">
                  <label class="form-label">Longitude</label>
                  <input type="number" step="any" class="form-control" id="editLongitude">
                </div>
              </div>
            </div>
            <div class="mb-3">
              <label class="form-label">Notes</label>
              <textarea class="form-control" id="editNotes" rows="2"></textarea>
            </div>
            <div class="mb-3">
              <div class="form-check form-switch">
                <input class="form-check-input" type="checkbox" id="editEnabled" checked>
                <label class="form-check-label" for="editEnabled">Enabled</label>
              </div>
            </div>
          </form>
        </div>
        <div class="modal-footer border-secondary">
          <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
          <button type="button" class="btn btn-primary" onclick="updateLocation()">
            <i class="fas fa-save"></i> Update Location
          </button>
        </div>
      </div>
    </div>
  </div>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
  <script>
    const locations = <%- JSON.stringify(locations) %>;

    async function geocodeAddress(mode) {
      const addressField = document.getElementById(mode + 'Address');
      const latField = document.getElementById(mode + 'Latitude');
      const lonField = document.getElementById(mode + 'Longitude');
      const address = addressField.value.trim();
      
      if (!address) {
        alert('Please enter an address first');
        return;
      }
      
      try {
        const response = await fetch('/settings/api/geocode', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ address })
        });
        
        const data = await response.json();
        if (data.success) {
          latField.value = data.lat;
          lonField.value = data.lon;
          alert('Geocoded successfully: ' + data.displayName);
        } else {
          alert('Could not geocode address: ' + (data.error || 'Unknown error'));
        }
      } catch (error) {
        alert('Error geocoding: ' + error.message);
      }
    }

    async function saveLocation() {
      const code = document.getElementById('addCode').value.trim();
      const name = document.getElementById('addName').value.trim();
      const address = document.getElementById('addAddress').value.trim();
      const latitude = document.getElementById('addLatitude').value;
      const longitude = document.getElementById('addLongitude').value;
      const notes = document.getElementById('addNotes').value.trim();
      
      if (!code || !name || !address) {
        alert('Code, name, and address are required');
        return;
      }
      
      try {
        const response = await fetch('/settings/api/known-locations', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ code, name, address, latitude, longitude, notes })
        });
        
        const data = await response.json();
        if (data.success) {
          location.reload();
        } else {
          alert('Error: ' + (data.error || 'Unknown error'));
        }
      } catch (error) {
        alert('Error saving: ' + error.message);
      }
    }

    function editLocation(id) {
      const loc = locations.find(l => l.id === id);
      if (!loc) return;
      
      document.getElementById('editId').value = loc.id;
      document.getElementById('editCode').value = loc.code;
      document.getElementById('editName').value = loc.name;
      document.getElementById('editAddress').value = loc.address;
      document.getElementById('editLatitude').value = loc.latitude || '';
      document.getElementById('editLongitude').value = loc.longitude || '';
      document.getElementById('editNotes').value = loc.notes || '';
      document.getElementById('editEnabled').checked = loc.enabled;
      
      new bootstrap.Modal(document.getElementById('editLocationModal')).show();
    }

    async function updateLocation() {
      const id = document.getElementById('editId').value;
      const code = document.getElementById('editCode').value.trim();
      const name = document.getElementById('editName').value.trim();
      const address = document.getElementById('editAddress').value.trim();
      const latitude = document.getElementById('editLatitude').value;
      const longitude = document.getElementById('editLongitude').value;
      const notes = document.getElementById('editNotes').value.trim();
      const enabled = document.getElementById('editEnabled').checked;
      
      if (!code || !name || !address) {
        alert('Code, name, and address are required');
        return;
      }
      
      try {
        const response = await fetch('/settings/api/known-locations/' + id, {
          method: 'PUT',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ code, name, address, latitude, longitude, notes, enabled })
        });
        
        const data = await response.json();
        if (data.success) {
          location.reload();
        } else {
          alert('Error: ' + (data.error || 'Unknown error'));
        }
      } catch (error) {
        alert('Error updating: ' + error.message);
      }
    }

    async function deleteLocation(id, code) {
      if (!confirm('Delete known location "' + code + '"?')) return;
      
      try {
        const response = await fetch('/settings/api/known-locations/' + id, {
          method: 'DELETE'
        });
        
        const data = await response.json();
        if (data.success) {
          location.reload();
        } else {
          alert('Error: ' + (data.error || 'Unknown error'));
        }
      } catch (error) {
        alert('Error deleting: ' + error.message);
      }
    }
  </script>
</body>
</html>
