  function addPriority(pattern, reason) {
    const statusEl = document.getElementById('priorityStatus');
    statusEl.innerHTML = '<span class="text-info"><i class="fas fa-spinner fa-spin"></i> Adding...</span>';
    
    fetch('/settings/api/add-priority', {
