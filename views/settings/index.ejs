  // Update loadFilters to also render priority table
  const originalLoadFilters = loadFilters;
  loadFilters = function() {
    fetch('/settings/api/get-filters')
      .then(res => res.json())
      .then(data => {
        filtersData = data;
        renderFiltersTable();
        renderPriorityTable();
      });
  };
  
  // Logs
  function loadLogs() {
    fetch('/settings/api/logs')
      .then(res => res.json())
      .then(data => {
        const select = document.getElementById('logFileSelect');
        select.innerHTML = '<option value="">Select a log file...</option>';
        
        if (data.files && data.files.length > 0) {
          data.files.forEach(file => {
            const option = document.createElement('option');
            option.value = file.name;
            option.textContent = file.name + ' (' + file.sizeFormatted + ')';
            select.appendChild(option);
          });
        }
      });
  }
  
  function viewLog() {
    const filename = document.getElementById('logFileSelect').value;
    const lines = document.getElementById('logLinesSelect').value;
    const contentEl = document.getElementById('logContent');
    
    if (!filename) {
      contentEl.textContent = 'Select a log file to view...';
      return;
    }
    
    contentEl.textContent = 'Loading...';
    
    fetch('/settings/api/logs/' + encodeURIComponent(filename) + '?lines=' + lines)
      .then(res => res.json())
      .then(data => {
        if (data.success) {
          contentEl.textContent = data.content || '(empty)';
          contentEl.scrollTop = contentEl.scrollHeight;
        } else {
          contentEl.textContent = 'Error: ' + (data.error || 'Failed to load log');
        }
      })
      .catch(err => {
        contentEl.textContent = 'Error: ' + err.message;
      });
  }
  
  function downloadLog() {
    const filename = document.getElementById('logFileSelect').value;
    if (!filename) {
      alert('Please select a log file first');
      return;
    }
    window.location.href = '/settings/api/logs/' + encodeURIComponent(filename) + '/download';
  }
  
  // Load logs on page load
  document.addEventListener('DOMContentLoaded', loadLogs);
</script>
