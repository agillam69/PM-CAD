  function viewUnknownMessages() {
    window.location.href = '/settings/unknown-messages';
  }
  
  function showAddService() {
    document.getElementById('serviceModalTitle').textContent = 'Add Service';
    document.getElementById('editingServiceKey').value = '';
    document.getElementById('serviceKey').value = '';
    document.getElementById('serviceKey').disabled = false;
    document.getElementById('serviceName').value = '';
    document.getElementById('serviceColor').value = '#28a745';
    document.getElementById('serviceIcon').value = '';
    document.getElementById('serviceAgencyMatch').value = '';
    new bootstrap.Modal(document.getElementById('serviceModal')).show();
  }
  
  function editService(key) {
    const service = servicesData[key];
    document.getElementById('serviceModalTitle').textContent = 'Edit Service';
    document.getElementById('editingServiceKey').value = key;
    document.getElementById('serviceKey').value = key;
    document.getElementById('serviceKey').disabled = true;
    document.getElementById('serviceName').value = service.name;
    document.getElementById('serviceColor').value = service.color;
    document.getElementById('serviceIcon').value = service.icon;
    document.getElementById('serviceAgencyMatch').value = (service.agencyMatch || []).join(', ');
    new bootstrap.Modal(document.getElementById('serviceModal')).show();
  }
  
  function saveService() {
    const editingKey = document.getElementById('editingServiceKey').value;
    const serviceKey = editingKey || document.getElementById('serviceKey').value;
    
    fetch('/settings/api/set-service', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        serviceKey,
        name: document.getElementById('serviceName').value,
        color: document.getElementById('serviceColor').value,
        icon: document.getElementById('serviceIcon').value,
        agencyMatch: document.getElementById('serviceAgencyMatch').value
      })
    })
    .then(res => res.json())
    .then(data => {
      if (data.success) {
        location.reload();
      }
    });
  }
  
  function deleteService(key) {
    if (!confirm('Delete service "' + key + '"?')) return;
    
    fetch('/settings/api/delete-service', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ serviceKey: key })
    })
    .then(res => res.json())
    .then(data => {
      if (data.success) {
        location.reload();
      }
    });
  }
  
  function importAliases() {
    const fileInput = document.getElementById('csvFile');
    const statusEl = document.getElementById('importStatus');
    
    if (!fileInput.files || !fileInput.files[0]) {
      statusEl.innerHTML = '<span class="text-danger"><i class="fas fa-times"></i> Please select a CSV file</span>';
      return;
    }
    
    const file = fileInput.files[0];
    const reader = new FileReader();
    
    reader.onload = function(e) {
      const csvData = e.target.result;
      
      statusEl.innerHTML = '<span class="text-info"><i class="fas fa-spinner fa-spin"></i> Processing...</span>';
      
      fetch('/settings/api/import-aliases', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ csvData })
      })
      .then(res => res.json())
      .then(data => {
        if (data.success) {
          let html = '<div class="alert alert-success">';
          html += '<strong><i class="fas fa-check"></i> Import Complete</strong><br>';
          html += 'Processed ' + data.imported + ' aliases from ' + data.agencies + ' agencies.<br>';
          html += '<small class="text-muted">Agencies found: ' + data.agencyList.join(', ') + '</small>';
          html += '</div>';
          statusEl.innerHTML = html;
        } else {
          statusEl.innerHTML = '<span class="text-danger"><i class="fas fa-times"></i> ' + data.error + '</span>';
        }
      })
      .catch(err => {
        statusEl.innerHTML = '<span class="text-danger"><i class="fas fa-times"></i> ' + err.message + '</span>';
      });
    };
    
    reader.readAsText(file);
  }
  
  function showAgencySummary() {
    fetch('/settings/api/aliases')
      .then(res => res.json())
      .then(data => {
        let html = '<div class="mt-3"><h6 class="text-light">Current Agency Configuration:</h6>';
        html += '<div class="table-responsive"><table class="table table-dark table-sm">';
        html += '<thead><tr><th>Service</th><th>Agencies</th></tr></thead><tbody>';
        
        for (const [key, info] of Object.entries(data)) {
          html += '<tr>';
          html += '<td><span class="badge" style="background-color: ' + info.color + ';">' + info.name + '</span></td>';
          html += '<td><small>' + info.agencies.join(', ') + '</small></td>';
          html += '</tr>';
        }
        
        html += '</tbody></table></div></div>';
        document.getElementById('importStatus').innerHTML = html;
      });
  }
  
  // Message Filters
  let filtersData = {};
  
  function loadFilters() {
    fetch('/settings/api/get-filters')
      .then(res => res.json())
      .then(data => {
        filtersData = data;
        renderFiltersTable();
      });
  }
  
  function renderFiltersTable() {
    const tbody = document.getElementById('filtersTable');
    const patterns = filtersData.excludePatterns || [];
    const reasons = filtersData.excludeReasons || {};
    
    if (patterns.length === 0) {
      tbody.innerHTML = '<tr><td colspan="3" class="text-muted text-center">No filters configured</td></tr>';
      return;
    }
    
    tbody.innerHTML = patterns.map((pattern, index) => 
      '<tr>' +
        '<td><code>' + escapeHtml(pattern) + '</code></td>' +
        '<td>' + escapeHtml(reasons[pattern] || 'No reason specified') + '</td>' +
        '<td>' +
          '<button class="btn btn-sm btn-outline-danger" onclick="deleteFilter(' + index + ')">' +
            '<i class="fas fa-trash"></i>' +
          '</button>' +
        '</td>' +
      '</tr>'
    ).join('');
  }
  
  function escapeHtml(text) {
    const div = document.createElement('div');
    div.textContent = text;
    return div.innerHTML;
  }
  
  function showAddFilter() {
    const pattern = prompt('Enter regex pattern to filter (e.g., ^@@\\\\)&\\\\)E51TIMEUPDATE):');
    if (!pattern) return;
    
    const reason = prompt('Enter reason for filtering (e.g., EAS Time Update):') || 'Filtered';
    
    addFilter(pattern, reason);
  }
  
  function addFilter(pattern, reason) {
    const statusEl = document.getElementById('filterStatus');
    statusEl.innerHTML = '<span class="text-info"><i class="fas fa-spinner fa-spin"></i> Adding filter...</span>';
    
    fetch('/settings/api/add-filter', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ pattern, reason })
    })
    .then(res => res.json())
    .then(data => {
      if (data.success) {
        statusEl.innerHTML = '<span class="text-success"><i class="fas fa-check"></i> Filter added</span>';
        loadFilters();
        setTimeout(() => { statusEl.innerHTML = ''; }, 2000);
      } else {
        statusEl.innerHTML = '<span class="text-danger"><i class="fas fa-times"></i> ' + (data.error || 'Failed to add filter') + '</span>';
      }
    });
  }
  
  function deleteFilter(index) {
    if (!confirm('Delete this filter?')) return;
    
    const statusEl = document.getElementById('filterStatus');
    statusEl.innerHTML = '<span class="text-info"><i class="fas fa-spinner fa-spin"></i> Deleting...</span>';
    
    fetch('/settings/api/delete-filter', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ index })
    })
    .then(res => res.json())
    .then(data => {
      if (data.success) {
        statusEl.innerHTML = '<span class="text-success"><i class="fas fa-check"></i> Filter deleted</span>';
        loadFilters();
        setTimeout(() => { statusEl.innerHTML = ''; }, 2000);
      } else {
        statusEl.innerHTML = '<span class="text-danger"><i class="fas fa-times"></i> Failed to delete</span>';
      }
    });
  }
  
  // Load filters on page load
  document.addEventListener('DOMContentLoaded', loadFilters);
  
  // Priority Patterns
  function renderPriorityTable() {
    const tbody = document.getElementById('priorityTable');
    const patterns = filtersData.priorityPatterns || [];
    const reasons = filtersData.priorityReasons || {};
    
    if (patterns.length === 0) {
      tbody.innerHTML = '<tr><td colspan="3" class="text-muted text-center">No priority patterns configured</td></tr>';
      return;
    }
    
    tbody.innerHTML = patterns.map((pattern, index) => 
      '<tr>' +
        '<td><code>' + escapeHtml(pattern) + '</code></td>' +
        '<td>' + escapeHtml(reasons[pattern] || 'Priority') + '</td>' +
        '<td>' +
          '<button class="btn btn-sm btn-outline-danger" onclick="deletePriority(' + index + ')">' +
            '<i class="fas fa-trash"></i>' +
          '</button>' +
        '</td>' +
      '</tr>'
    ).join('');
  }
  
  function showAddPriority() {
    const pattern = prompt('Enter regex pattern for priority (e.g., SIG1, MICA, CODE\\\\s*1):');
    if (!pattern) return;
    
    const reason = prompt('Enter reason (e.g., Signal 1 - Lights & Sirens):') || 'Priority';
    
    addPriority(pattern, reason);
