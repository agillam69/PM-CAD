  function deletePriority(index) {
    if (!confirm('Delete this priority pattern?')) return;
    
    const statusEl = document.getElementById('priorityStatus');
    statusEl.innerHTML = '<span class="text-info"><i class="fas fa-spinner fa-spin"></i> Deleting...</span>';
    
    fetch('/settings/api/delete-priority', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ index })
    })
    .then(res => res.json())
    .then(data => {
      if (data.success) {
        statusEl.innerHTML = '<span class="text-success"><i class="fas fa-check"></i> Deleted</span>';
        loadFilters();
        setTimeout(() => { statusEl.innerHTML = ''; }, 2000);
      } else {
        statusEl.innerHTML = '<span class="text-danger"><i class="fas fa-times"></i> Failed</span>';
      }
    });
