<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Auto-Print Settings - CAD</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" rel="stylesheet">
  <style>
    body { background-color: #1a1a2e; color: #fff; }
    .navbar { background-color: #16213e !important; }
    .card { background-color: #16213e; border: 1px solid #0f3460; }
    .card-header { background-color: #0f3460; border-bottom: 1px solid #0f3460; }
    .table { color: #fff; }
    .btn-close-white { filter: invert(1); }
    .form-check-input:checked { background-color: #0d6efd; border-color: #0d6efd; }
  </style>
</head>
<body>
  <nav class="navbar navbar-expand-lg navbar-dark mb-4">
    <div class="container-fluid">
      <a class="navbar-brand" href="/cad"><i class="fas fa-broadcast-tower"></i> CAD Dispatch</a>
      <div class="navbar-nav ms-auto">
        <a class="nav-link" href="/settings"><i class="fas fa-arrow-left"></i> Back to Settings</a>
        <a class="nav-link" href="/cad"><i class="fas fa-th-list"></i> Board</a>
      </div>
    </div>
  </nav>

  <div class="container-fluid">
    <div class="row mb-4">
      <div class="col-12">
        <div class="d-flex justify-content-between align-items-center">
          <h2><i class="fas fa-print"></i> Auto-Print Settings</h2>
          <button class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#addCapcodeModal">
            <i class="fas fa-plus"></i> Add Capcode
          </button>
        </div>
        <p class="text-muted mt-2">
          Configure capcodes that should automatically trigger printing when a message is received.
          The system will open a print dialog for the configured document type(s).
        </p>
      </div>
    </div>

    <div class="row">
      <div class="col-lg-8">
        <div class="card">
          <div class="card-header">
            <i class="fas fa-list"></i> Auto-Print Capcodes
            <span class="badge bg-secondary"><%= capcodes.length %></span>
          </div>
          <div class="card-body">
            <table class="table table-dark table-hover">
              <thead>
                <tr>
                  <th>Capcode</th>
                  <th>Alias</th>
                  <th>Dispatch Slip</th>
                  <th>Case Log</th>
                  <th>Status</th>
                  <th>Actions</th>
                </tr>
              </thead>
              <tbody>
                <% capcodes.forEach(function(c) { %>
                <tr>
                  <td><code><%= c.capcode %></code></td>
                  <td><%= c.alias || '-' %></td>
                  <td>
                    <% if (c.print_dispatch) { %>
                      <span class="badge bg-success"><i class="fas fa-check"></i></span>
                    <% } else { %>
                      <span class="badge bg-secondary"><i class="fas fa-times"></i></span>
                    <% } %>
                  </td>
                  <td>
                    <% if (c.print_log) { %>
                      <span class="badge bg-success"><i class="fas fa-check"></i></span>
                    <% } else { %>
                      <span class="badge bg-secondary"><i class="fas fa-times"></i></span>
                    <% } %>
                  </td>
                  <td>
                    <% if (c.enabled) { %>
                      <span class="badge bg-success">Enabled</span>
                    <% } else { %>
                      <span class="badge bg-secondary">Disabled</span>
                    <% } %>
                  </td>
                  <td>
                    <button class="btn btn-sm btn-outline-primary" onclick="editCapcode(<%= c.id %>, '<%= c.capcode %>', '<%= c.alias || '' %>', <%= c.print_dispatch %>, <%= c.print_log %>, <%= c.enabled %>)">
                      <i class="fas fa-edit"></i>
                    </button>
                    <button class="btn btn-sm btn-outline-danger" onclick="deleteCapcode(<%= c.id %>, '<%= c.capcode %>')">
                      <i class="fas fa-trash"></i>
                    </button>
                  </td>
                </tr>
                <% }); %>
                <% if (capcodes.length === 0) { %>
                <tr>
                  <td colspan="6" class="text-center text-muted">No auto-print capcodes configured</td>
                </tr>
                <% } %>
              </tbody>
            </table>
          </div>
        </div>
      </div>
      
      <div class="col-lg-4">
        <div class="card mb-4">
          <div class="card-header">
            <i class="fas fa-info-circle"></i> How It Works
          </div>
          <div class="card-body">
            <p class="small mb-2">When a message arrives from a configured capcode:</p>
            <ol class="small">
              <li>The system checks if the capcode is in this list</li>
              <li>If enabled, it opens a new browser tab with the PDF</li>
              <li>The browser's print dialog appears automatically</li>
            </ol>
            <p class="small text-warning mb-0">
              <i class="fas fa-exclamation-triangle"></i> 
              Requires the CAD board to be open in a browser for auto-print to work.
            </p>
          </div>
        </div>
        
        <div class="card">
          <div class="card-header">
            <i class="fas fa-file-alt"></i> Print Types
          </div>
          <div class="card-body">
            <p class="small mb-2"><strong>Dispatch Slip (A5):</strong></p>
            <ul class="small mb-3">
              <li>Quick grab-and-go format</li>
              <li>Centered pager message</li>
              <li>Address and map reference</li>
              <li>Radio channel (fire)</li>
            </ul>
            <p class="small mb-2"><strong>Case Log (A4):</strong></p>
            <ul class="small mb-0">
              <li>Full after-action report</li>
              <li>All messages and notes</li>
              <li>Units assigned</li>
            </ul>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Add Capcode Modal -->
  <div class="modal fade" id="addCapcodeModal" tabindex="-1">
    <div class="modal-dialog">
      <div class="modal-content bg-dark">
        <div class="modal-header">
          <h5 class="modal-title"><i class="fas fa-plus"></i> Add Auto-Print Capcode</h5>
          <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
        </div>
        <form id="addCapcodeForm" onsubmit="addCapcode(event)">
          <div class="modal-body">
            <div class="mb-3">
              <label class="form-label">Capcode</label>
              <input type="text" class="form-control bg-dark text-white" name="capcode" placeholder="e.g., 1234567" required>
              <small class="text-muted">The numeric capcode from PagerMon</small>
            </div>
            <div class="mb-3">
              <label class="form-label">Alias (optional)</label>
              <input type="text" class="form-control bg-dark text-white" name="alias" placeholder="e.g., Station 43">
              <small class="text-muted">Friendly name for reference</small>
            </div>
            <div class="mb-3">
              <div class="form-check">
                <input type="checkbox" class="form-check-input" name="printDispatch" id="addPrintDispatch" checked>
                <label class="form-check-label" for="addPrintDispatch">Print Dispatch Slip</label>
              </div>
              <div class="form-check">
                <input type="checkbox" class="form-check-input" name="printLog" id="addPrintLog">
                <label class="form-check-label" for="addPrintLog">Print Case Log</label>
              </div>
            </div>
          </div>
          <div class="modal-footer">
            <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
            <button type="submit" class="btn btn-primary">Add Capcode</button>
          </div>
        </form>
      </div>
    </div>
  </div>

  <!-- Edit Capcode Modal -->
  <div class="modal fade" id="editCapcodeModal" tabindex="-1">
    <div class="modal-dialog">
      <div class="modal-content bg-dark">
        <div class="modal-header">
          <h5 class="modal-title"><i class="fas fa-edit"></i> Edit Auto-Print Capcode</h5>
          <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
        </div>
        <form id="editCapcodeForm" onsubmit="saveCapcode(event)">
          <input type="hidden" name="capcodeId" id="editCapcodeId">
          <div class="modal-body">
            <div class="mb-3">
              <label class="form-label">Capcode</label>
              <input type="text" class="form-control bg-dark text-white" name="capcode" id="editCapcodeValue" required>
            </div>
            <div class="mb-3">
              <label class="form-label">Alias (optional)</label>
              <input type="text" class="form-control bg-dark text-white" name="alias" id="editAlias">
            </div>
            <div class="mb-3">
              <div class="form-check">
                <input type="checkbox" class="form-check-input" name="printDispatch" id="editPrintDispatch">
                <label class="form-check-label" for="editPrintDispatch">Print Dispatch Slip</label>
              </div>
              <div class="form-check">
                <input type="checkbox" class="form-check-input" name="printLog" id="editPrintLog">
                <label class="form-check-label" for="editPrintLog">Print Case Log</label>
              </div>
              <div class="form-check mt-2">
                <input type="checkbox" class="form-check-input" name="enabled" id="editEnabled">
                <label class="form-check-label" for="editEnabled">Enabled</label>
              </div>
            </div>
          </div>
          <div class="modal-footer">
            <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
            <button type="submit" class="btn btn-primary">Save Changes</button>
          </div>
        </form>
      </div>
    </div>
  </div>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
  <script>
    function addCapcode(event) {
      event.preventDefault();
      var form = event.target;
      var data = {
        capcode: form.capcode.value,
        alias: form.alias.value,
        printDispatch: form.printDispatch.checked,
        printLog: form.printLog.checked
      };
      
      fetch('/settings/api/auto-print', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(data)
      })
      .then(function(res) { return res.json(); })
      .then(function(result) {
        if (result.success) {
          location.reload();
        } else {
          alert('Error: ' + result.error);
        }
      })
      .catch(function(err) { alert('Error adding capcode'); });
    }
    
    function editCapcode(id, capcode, alias, printDispatch, printLog, enabled) {
      document.getElementById('editCapcodeId').value = id;
      document.getElementById('editCapcodeValue').value = capcode;
      document.getElementById('editAlias').value = alias;
      document.getElementById('editPrintDispatch').checked = printDispatch;
      document.getElementById('editPrintLog').checked = printLog;
      document.getElementById('editEnabled').checked = enabled;
      
      new bootstrap.Modal(document.getElementById('editCapcodeModal')).show();
    }
    
    function saveCapcode(event) {
      event.preventDefault();
      var form = event.target;
      var id = document.getElementById('editCapcodeId').value;
      var data = {
        capcode: form.capcode.value,
        alias: form.alias.value,
        printDispatch: form.printDispatch.checked,
        printLog: form.printLog.checked,
        enabled: form.enabled.checked
      };
      
      fetch('/settings/api/auto-print/' + id, {
        method: 'PUT',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(data)
      })
      .then(function(res) { return res.json(); })
      .then(function(result) {
        if (result.success) {
          location.reload();
        } else {
          alert('Error: ' + result.error);
        }
      })
      .catch(function(err) { alert('Error updating capcode'); });
    }
    
    function deleteCapcode(id, capcode) {
      if (!confirm('Delete auto-print for capcode "' + capcode + '"?')) {
        return;
      }
      
      fetch('/settings/api/auto-print/' + id, {
        method: 'DELETE'
      })
      .then(function(res) { return res.json(); })
      .then(function(result) {
        if (result.success) {
          location.reload();
        } else {
          alert('Error: ' + result.error);
        }
      })
      .catch(function(err) { alert('Error deleting capcode'); });
    }
  </script>
</body>
</html>
